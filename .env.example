# いきもの図鑑カード — Azure OpenAI / Foundry 画像生成用の環境変数サンプル
# このファイルをコピーして `.env` を作成し、各値を実環境に合わせて設定してください。
# `.env` は `.gitignore` で除外されています（このサンプルだけリポジトリに含めます）。

# --- 必須 ---
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-api-key>

# --- v1 (Foundry Models REST API v1) で叩く場合（既定） ---
# モデル名（Foundry のデプロイ名と同名にしているケースが多い）
AZURE_OPENAI_IMAGE_MODEL=gpt-image-2-1

# --- 旧 deployment 方式で叩く場合は以下を併用 ---
# AZURE_OPENAI_API_MODE=deployment
# AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-2-1
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# --- 任意 ---
# AZURE_OPENAI_TIMEOUT=600
